{
  "_version": "1.82.0",
  "sap.app": {
    "id": "com.sap.omtool.omtool",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.20.3",
      "toolsId": "212b1d01-f414-4d76-9729-f9cdf767a60f"
    },
    "dataSources": {
      "mainServiceV4": {
        "uri": "/odata/v4/omtsrv/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.01"
        }
      },
      "mainService": {
        "uri": "/odata/v2/omtsrv/",
        "type": "OData",
        "settings": {
          "odataVersion": "2.0",
          "localUri": "localService/metadata.xml"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.145.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "com.sap.omtool.omtool.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "controlAggregation": "pages",
        "controlId": "app",
        "transition": "slide",
        "type": "View",
        "viewType": "XML",
        "path": "com.sap.omtool.omtool.view",
        "async": true,
        "viewPath": "com.sap.omtool.omtool.view"
      },
      "routes": [
        {
          "name": "RouteEmployeeHeader",
          "pattern": "",
          "target": [
            "TargetEmployeeHeader"
          ]
        },
        {
          "pattern": "reports",
          "name": "Reports",
          "target": "TargetReports"
        }
      ],
      "targets": {
        "TargetEmployeeHeader": {
          "id": "EmployeeHeader",
          "name": "EmployeeHeader"
        },
        "TargetReports": {
          "id": "Reports",
          "name": "Reports"
        }
      }
    },
    "rootView": {
      "viewName": "com.sap.omtool.omtool.view.App",
      "type": "XML",
      "id": "App",
      "async": true
    }
  }
}