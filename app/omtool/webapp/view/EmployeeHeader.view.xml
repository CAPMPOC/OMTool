<mvc:View controllerName="com.sap.omtool.omtool.controller.EmployeeHeader"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:smartTable="sap.ui.comp.smarttable"
    xmlns:core="sap.ui.core"
    xmlns:smartFilterBar="sap.ui.comp.smartfilterbar"
    xmlns="sap.m"
    height="100%">
    <Page id="page" title="{i18n>title}">
        <content>

            <core:Fragment fragmentName="com.sap.omtool.omtool.view.fragments.FilterBar" type="XML"/>
            
            <smartTable:SmartTable
                id="smartTable"
                entitySet="EmployeeHeader"
                smartFilterId="smartFilterBar"
                tableType="ResponsiveTable"
                useExportToExcel="true"
                useVariantManagement="true"
                useTablePersonalisation="true"
                header="Employee Data"
                showRowCount="true"
                persistencyKey="EmployeeHeaderSmartTable"
                enableAutoBinding="true"
                demandPopin="true"
                class="sapUiResponsiveContentPadding">
    <smartTable:customToolbar>
        <OverflowToolbar id="_toolBar" design="Transparent">
            <ToolbarSpacer id="IdToolBar"/>
            <Button id="_addEmpBtn" class="sapUiSmallMargin" icon="sap-icon://add-employee" type="Default"
					badgeStyle="Default" text="Add Employee" press="onAddEmployee"/>
                    </OverflowToolbar>
    </smartTable:customToolbar>
    <Table id="innerTable" mode="None">
        <columns>
            <!-- Actions Column -->
            <Column 
                width="8em" 
                hAlign="Center"
                demandPopin="false">
                <customData>
                    <core:CustomData 
                        key="p13nData" 
                        value='\{"columnKey":"Actions", "columnIndex":"999"}' />
                </customData>
                <Text text="Actions"/>
            </Column>
        </columns>
        
        <items>
            <ColumnListItem>
                <cells>
                    <!-- Actions Cell -->
                    <HBox 
    justifyContent="Center" 
    class="sapUiTinyMarginBeginEnd">
    <core:Icon
        src="sap-icon://show"
        color="#0a6ed1"
        press="onViewEmployee"
        class="sapUiSmallMarginEnd sapUiTinyMarginTop"
        tooltip="View">
        <core:layoutData>
            <FlexItemData growFactor="0"/>
        </core:layoutData>
    </core:Icon>
    <core:Icon
        src="sap-icon://edit"
        color="#0854a0"
        press="onEdit"
        class="sapUiSmallMarginEnd sapUiTinyMarginTop"
        tooltip="Edit">
        <core:layoutData>
            <FlexItemData growFactor="0"/>
        </core:layoutData>
    </core:Icon>
    <!-- <core:Icon
        src="sap-icon://delete"
        color="#bb0000"
        press="onDelete"
        class="sapUiTinyMarginTop"
        tooltip="Delete">
        <core:layoutData>
            <FlexItemData growFactor="0"/>
        </core:layoutData>
    </core:Icon> -->
</HBox>
                </cells>
            </ColumnListItem>
        </items>
    </Table>
                    </smartTable:SmartTable>
        </content>
    </Page>
</mvc:View>