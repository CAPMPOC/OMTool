<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout">
    
    <Dialog
        id="employeeDialog"
        title="Add Employee"
        contentWidth="500px"
        contentHeight="auto"
        resizable="false"
        draggable="true">
        
        <content>
            <VBox id="vboxMain" class="sapUiSmallMarginBegin sapUiSmallMarginTop">
                <Title 
                        id="titleBasicInformation" 
                        text="Basic Information" 
                        level="H4"
                        class="sapUiSmallMarginBottom"/>
                <!-- Employee ID -->
                <VBox id="vboxEmployeeId" class="sapUiSmallMarginBottom">
                    <Label id="lblEmployeeId" text="Employee ID" required="true"/>
                    <Input 
                        id="inputEmployeeId" 
                        value="{employee>/Empid}"
                        width="98%"
                        placeholder=""/>
                </VBox>
                
                <HBox id="hboxNames">
                <VBox id="vboxFirstName" class="sapUiSmallMarginEnd" width="48%">
                    <Label id="lblFirstName" text="First Name" required="true"/>
                    <Input 
                        id="inputFirstName" 
                        value="{employee>/firstName}"
                        width="100%"
                        placeholder=""/>
                </VBox>
                <VBox id="vboxLastName" class="sapUiSmallMarginEnd" width="48%">
                    <Label id="lblLastName" text="Last Name" required="true"/>
                    <Input 
                        id="inputLastName" 
                        value="{employee>/lastName}"
                        width="100%"
                        placeholder=""/>
                </VBox>
                </HBox>
                
                <!-- Address -->
                <HBox >
                <VBox id="vboxLocation" width="48%" class="sapUiSmallMarginEnd">
                    <Label id="lblLocation" text="Employee Location"/>
                    <Input 
                        id="inputEmployeeLocation" 
                        value="{employee>/locationDesc}"
                        width="100%"
                        placeholder="Select Location"
                        showClearIcon="true"
                        showValueHelp="true"
                        valueHelpRequest=".onEmployeeLocationValueHelp"
                        showSuggestion="true"
                        suggestionItems="{path: '/LocationVH'}"
                        suggest=".onEmployeeLocationSuggest"
                        suggestionItemSelected=".onEmployeeLocationSuggestionSelected"
                        change=".onEmployeeLocationChange">
                        <suggestionItems>
                            <core:Item 
                                key="{LocID}" 
                                text="{LocDesc}"/>
                    </suggestionItems>
                </Input>
                </VBox>

                <VBox id="vboxCuserId" width="48%" class="sapUiSmallMarginEnd">
                    <Label id="lblCuserId" text="C-User ID"/>
                    <Input 
                        id="inputCuserId" 
                        value="{employee>/CID}"
                        width="100%"
                        placeholder=""/>
                </VBox>
                </HBox>
                
                <!-- Date Fields Row -->
                <Title 
                        id="titleAssignment" 
                        text="Assignment" 
                        level="H4"
                        class="sapUiSmallMarginBottom sapUiSmallMarginTop"/>

                         <!-- Employer Name -->
                <VBox
                    id="vboxEmployerName">
                    <Label
                        id="lblEmployerName"
                        text="Employer Name" />
                    <Input
                        id="inputEmployerName"
                        value="{employee>/Employer}"
                        width="98%"
                        placeholder="" />
                </VBox>
                    <HBox>
                  <VBox id="vboxProductGroup" width="48%" class="sapUiSmallMarginEnd">
                    <Label id="lblProductGroup" text="ProductGroup"/>
                    <Input 
                        id="inputProductGroup" 
                        value="{employee>/ProductGroup}"
                        width="100%"
                        placeholder=""/>
                </VBox>

                <VBox id="vboxServiceGroup" width="48%" class="sapUiSmallMarginEnd">
                    <Label id="lblServiceGroup" text="Service Group"/>
                    <Input 
                        id="inputServiceGroup" 
                        value="{employee>/ServiceGroup}"
                        width="100%"
                        placeholder=""/>
                </VBox>
                </HBox>

                <HBox id="hboxProduct">
                <VBox id="vboxProduct"  width="48%" class="sapUiSmallMarginEnd">
                    <Label id="lblProduct" text="Product"/>
                    <Input 
                        id="inputProduct" 
                        value="{employee>/Product}"
                        width="100%"
                        placeholder=""/>
                </VBox>   

                <VBox id="vboxAccessibility"  width="48%" class="sapUiSmallMarginEnd">
                    <Label id="lblAccessibility" text="Position"/>
                    <ComboBox
                        id="PositionAddEmployee"
                        placeholder="Position"
                        width="240px"
                        class="sapUiTinyMarginEnd"
                        showClearIcon="true"
                        selectedKey="{employee>/Accessibility}"
                        items="{
                            path: '/AccessibilityVH'
                            }">
                    <core:Item key="{AccessID}" text="{Description}" />
                </ComboBox>
                </VBox>      
                </HBox>
                <HBox id="hboxDates" class="sapUiSmallMarginTop">
                    
                    <!-- Kick-off Date -->
                    <VBox id="vboxKickOffDate" width="48%" class="sapUiSmallMarginEnd">
                    
                        <Label id="lblKickOffDate" text="Roll-On Date" required="true"/>
                        <DatePicker
                            id="dpKickOffDate"
                            value="{employee>/rollOnDate}"
                            valueFormat="yyyy-MM-dd"
                            displayFormat="MM/dd/yyyy"
                            width="100%"
                            placeholder="mm/dd/yyyy"
                            />
                    </VBox>
                    
                    <!-- Roll-off Date -->
                    <VBox id="vboxRollOffDate" width="48%" class="sapUiSmallMarginEnd">
                        <Label id="lblRollOffDate" text="Roll-off Date"/>
                        <DatePicker
                            id="dpRollOffDate"
                            value="{employee>/rollOffDate}"
                            valueFormat="yyyy-MM-dd"
                            displayFormat="MM/dd/yyyy"
                            width="100%"
                            placeholder="mm/dd/yyyy"/>
                    </VBox>
                </HBox>
                
                <!-- EXPERIENCE SECTION -->
                <Title
                    id="titleExperience"
                    text="Experience"
                    level="H4"
                    class="sapUiSmallMarginBottom sapUiSmallMarginTop" />
                
                <!-- SAP and Non-SAP Experience -->
                <HBox id="hboxSAPExperience">
                    <VBox
                        id="vboxSAPExperience"
                        width="30%"
                        class="sapUiSmallMarginEnd">
                        <Label
                            id="lblSAPExperience"
                            text="SAP Experience"
                            required="true" />
                        <Input
                            id="sapExperience"
                            value="{employee>/SAP}"
                            width="100%" />
                    </VBox>
                    
                    <VBox
                        id="vboxNonSAPExp"
                        width="30%"
                        class="sapUiSmallMarginEnd">
                        <Label
                            id="lblNonSAPExp"
                            text="Non-SAP Experience" />
                        <Input
                            id="inputNonSAPExp"
                            value="{employee>/NonSAP}"
                            width="100%"  />
                    </VBox>

                    <VBox
                        id="vboxTotalExp"
                        width="30%"
                        class="sapUiSmallMarginEnd">
                        <Label
                            id="lblTotalExp"
                            text="Total Experience" />
                        <Input
                            id="inputTotalExp"
                            value="{employee>/SAPToday}"
                            width="100%"
                            placeholder=""  enabled="false"/>
                    </VBox>
                </HBox>
                
                <!-- Total Experience and Skills -->
                <!-- <HBox id="hboxTotalExpSkills"> -->
                    
                    
                    <VBox
                        id="vboxEmpSkill">
                        <Label
                            id="lblEmpSkill"
                            text="Employee Skills" />
                        <Input
                            id="inputEmpSkill"
                            value="{employee>/Skill_SkillID}"
                            width="98%"
                            placeholder="" />
                    </VBox>
                <!-- </HBox> -->
                
                
                <!-- Status Tracking Section -->
                <VBox id="vboxStatusTracking" class="sapUiMediumMarginTop">
                    
                    <!-- Status Tracking Title -->
                    <Title 
                        id="titleStatusTracking" 
                        text="Status Tracking" 
                        level="H4"/>
                    <HBox id="hboxStatusSwitches">
                    <HBox
                        id="hboxRollOffStarted"
                        justifyContent="Start"
                        alignItems="Center"
                        width="50%"
                        class="sapUiSmallMarginTop">
                        <Text
                            id="txtRollOffStarted"
                            text="Roll-off Started" />
                        <Switch
                            id="switchRollOffStarted"
                            state="true"  customTextOn="Yes" customTextOff="No" />
                    </HBox>
                    
                    <HBox
                        id="hboxHandoverKT"
                        justifyContent="Start"
                        alignItems="Center"
                        width="50%"
                        class="sapUiSmallMarginTop">
                        <Text
                            id="txtHandoverKT"
                            text="Handover/KT Begun" />
                        <Switch
                            id="switchHandoverKT"
                            state="true"  customTextOn="Yes" customTextOff="No" />
                    </HBox>
                </HBox>
                    
                </VBox>
                
            </VBox>
        </content>
        
        <buttons>
            <Button 
                id="btnCancel"
                text="Cancel" 
                press="onCancelEmployee"/>
            <Button 
                id="btnAddEmployee"
                text="Add Employee" 
                type="Emphasized"
                press="onAddEmployeePress"/>
        </buttons>
    </Dialog>
</core:FragmentDefinition>