<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout">
    
    <Dialog
        id="employeeDialog"
        title="Add Employee"
        contentWidth="500px"
        contentHeight="auto"
        resizable="false"
        draggable="true">
        
        <content>
            <VBox
                id="vboxMain"
                class="sapUiSmallMarginBegin sapUiSmallMarginTop">
                
                <!-- BASIC INFORMATION SECTION -->
                <Title
                    id="titleBasicInformation"
                    text="Basic Information"
                    level="H4"
                    class="sapUiSmallMarginBottom" />
                
                <!-- Employee ID -->
                <VBox id="vboxEmployeeId">
    <Label
        id="lblEmployeeId"
        text="Employee ID"
        required="true" />
    <Input
        id="inputEmployeeId"
        value="{employee>/Empid}"
        width="95%"
        placeholder="" />
</VBox>

                
                <!-- First Name and Last Name -->
                <HBox id="hboxNames">
                    <VBox
                        id="vboxFirstName"
                        class="sapUiSmallMarginEnd"
                        width="48%">
                        <Label
                            id="lblFirstName"
                            text="First Name"
                            required="true" />
                        <Input
                            id="inputFirstName"
                            value="{employee>/FirstName}"
                            width="100%"
                            placeholder="" />
                    </VBox>
                    
                    <VBox
                        id="vboxLastName"
                        class="sapUiSmallMarginEnd"
                        width="48%">
                        <Label
                            id="lblLastName"
                            text="Last Name"
                            required="true" />
                        <Input
                            id="inputLastName"
                            value="{employee>/LastName}"
                            width="100%"
                            placeholder="" />
                    </VBox>
                </HBox>
                
                <!-- Location and C-User ID -->
                <HBox id="hboxLocationCuserId">
                    <VBox
                        id="vboxLocation"
                        width="48%"
                        class="sapUiSmallMarginEnd">
                        <Label
                            id="lblLocation"
                            text="Employee Location" />
                        <Input
                            id="inputLocation"
                            value="{employee>/Location_LocID}"
                            width="100%"
                            placeholder="" />
                    </VBox>
                    
                    <VBox
                        id="vboxCuserId"
                        width="48%"
                        class="sapUiSmallMarginEnd">
                        <Label
                            id="lblCuserId"
                            text="C-User ID" />
                        <Input
                            id="inputCuserId"
                            value="{employee>/CID}"
                            width="100%"
                            placeholder="" />
                    </VBox>
                </HBox>
                
                <!-- On-boarding KT Switch -->
                <HBox
                    id="hboxObKtBegun"
                    justifyContent="Start"
                    alignItems="Center"
                    width="100%"
                    class="sapUiSmallMarginTop">
                    <Text
                        id="txtNewEmployee"
                        text="Has on-boarding KT begun " />
                    <Switch
                        id="obKtBegun"
                        state="{employee>/ktStarted}"  customTextOn="Yes" customTextOff="No" />
                </HBox>
                
                <!-- ASSIGNMENT SECTION -->
                <Title
                    id="titleAssignment"
                    text="Assignment"
                    level="H4"
                    class="sapUiSmallMarginBottom sapUiSmallMarginTop" />
                
                <!-- Employer Name -->
                <VBox
                    id="vboxEmployerName">
                    <Label
                        id="lblEmployerName"
                        text="Employer Name" />
                    <Input
                        id="inputEmployerName"
                        value="{employee>/Employer}"
                        width="95%"
                        placeholder="" />
                </VBox>
                
                <!-- Product Group and Service Group -->
                <HBox id="hboxProductService">
                    <VBox
                        id="vboxProductGroup"
                        width="48%"
                        class="sapUiSmallMarginEnd">
                        <Label
                            id="lblProductGroup"
                            text="Product Group" />
                        <Input
                            id="inputProductGroup"
                            value="{employee>/ProductGroup}"
                            width="100%"
                            placeholder="" />
                    </VBox>
                    
                    <VBox
                        id="vboxServiceGroup"
                        width="48%">
                        <Label
                            id="lblServiceGroup"
                            text="Service Group" />
                        <Input
                            id="inputServiceGroup"
                            value="{employee>/ServiceGroup}"
                            width="100%"
                            placeholder="" />
                    </VBox>
                </HBox>
                
                <!-- Product and Position -->
                <HBox id="hboxProductPosition">
                    <VBox
                        id="vboxProduct"
                        width="48%"
                        class="sapUiSmallMarginEnd">
                        <Label
                            id="lblProduct"
                            text="Product" />
                        <Input
                            id="inputProduct"
                            value="{employee>/Product}"
                            width="100%"
                            placeholder="" />
                    </VBox>
                    
                    <VBox
                        id="vboxPosition"
                        width="48%">
                        <Label
                            id="lblPosition"
                            text="Position" />
                        <Input
                            id="inputPosition"
                            value="{employee>/Accessibility_AccessID}"
                            width="100%"
                            placeholder="" />
                    </VBox>
                </HBox>
                
                <!-- EXPERIENCE SECTION -->
                <Title
                    id="titleExperience"
                    text="Experience"
                    level="H4"
                    class="sapUiSmallMarginBottom sapUiSmallMarginTop" />
                
                <!-- SAP and Non-SAP Experience -->
                <HBox id="hboxSAPExperience">
                    <VBox
                        id="vboxSAPExperience"
                        width="48%"
                        class="sapUiSmallMarginEnd">
                        <Label
                            id="lblSAPExperience"
                            text="SAP Experience"
                            required="true" />
                        <Input
                            id="sapExperience"
                            value="{employee>/SAP}"
                            width="100%" />
                    </VBox>
                    
                    <VBox
                        id="vboxNonSAPExp"
                        width="48%"
                        class="sapUiSmallMarginEnd">
                        <Label
                            id="lblNonSAPExp"
                            text="Non-SAP Experience" />
                        <Input
                            id="inputNonSAPExp"
                            value="{employee>/NonSAP}"
                            width="100%"
                            placeholder="" />
                    </VBox>
                </HBox>
                
                <!-- Total Experience and Skills -->
                <HBox id="hboxTotalExpSkills">
                    <VBox
                        id="vboxTotalExp"
                        width="48%"
                        class="sapUiSmallMarginEnd">
                        <Label
                            id="lblTotalExp"
                            text="Total Experience" />
                        <Input
                            id="inputTotalExp"
                            value="{employee>/SAPToday}"
                            width="100%"
                            placeholder="" />
                    </VBox>
                    
                    <VBox
                        id="vboxEmpSkill"
                        width="48%"
                        class="sapUiSmallMarginEnd">
                        <Label
                            id="lblEmpSkill"
                            text="Employee Skills" />
                        <Input
                            id="inputEmpSkill"
                            value="{employee>/Skill_SkillID}"
                            width="100%"
                            placeholder="" />
                    </VBox>
                </HBox>
                
                <!-- ROLL-OFF DETAILS SECTION -->
                <Title
                    id="titleRollOf"
                    text="Roll-off Details"
                    level="H4"
                    class="sapUiSmallMarginBottom sapUiMediumMarginTop" />
                
                <!-- Roll-off Reason and Remarks -->
                <HBox id="hboxRollOffReasons">
                    <VBox
                        id="vboxEmpRfReason"
                        width="48%"
                        class="sapUiSmallMarginEnd">
                        <Label
                            id="lblEmpRfReason"
                            text="Employee Roll-off Reason" />
                        <Input
                            id="inputEmpRfReason"
                            value="{employee>/Staff_RollOffReasons}"
                            width="100%"
                            placeholder="" />
                    </VBox>
                    
                    <VBox
                        id="vboxStaffRemarks"
                        width="48%"
                        class="sapUiSmallMarginEnd">
                        <Label
                            id="lblStaffRemarks"
                            text="Reasons/Remarks" />
                        <Input
                            id="inputStaffRemarks"
                            value="{employee>/Staff_ReasonsRemarks}"
                            width="100%"
                            placeholder="" />
                    </VBox>
                </HBox>
                
                <!-- Roll-on and Roll-off Dates -->
                <HBox
                    id="hboxDates"
                    class="sapUiSmallMarginTop">
                    <VBox
                        id="vboxRollOnDate"
                        width="48%"
                        class="sapUiSmallMarginEnd">
                        <Label
                            id="lblRollOnDate"
                            text="Roll-on Date"
                            required="true" />
                        <DatePicker
                            id="dpRollOnDate"
                            value="{employee>/RollOnDate}"
                            valueFormat="yyyy-MM-dd"
                            displayFormat="MM/dd/yyyy"
                            width="100%"
                            placeholder="mm/dd/yyyy" />
                    </VBox>
                    
                    <VBox
                        id="vboxRollOffDate"
                        width="48%">
                        <Label
                            id="lblRollOffDate"
                            text="Roll-off Date" />
                        <DatePicker
                            id="dpRollOffDate"
                            value="{employee>/RollOffDate}"
                            valueFormat="yyyy-MM-dd"
                            displayFormat="MM/dd/yyyy"
                            width="100%"
                            placeholder="mm/dd/yyyy" />
                    </VBox>
                </HBox>
                
                <!-- Impact of Roll Off -->
                <VBox
                    id="vboxRollOffImpact"
                    width="48%"
                    class="sapUiSmallMarginTop">
                    <Label
                        id="lblRollOffImpact"
                        text="Impact of Roll Off" />
                        <Input
                            id="inputRollOffImpact"
                            value="{employee>/RollOffImpact_ROI}"
                            width="100%"
                            placeholder="" />
                        
                    
                </VBox>
                
                <!-- Status Switches -->
                <HBox id="hboxStatusSwitches">
                    <HBox
                        id="hboxRollOffStarted"
                        justifyContent="Start"
                        alignItems="Center"
                        width="50%"
                        class="sapUiSmallMarginTop">
                        <Text
                            id="txtRollOffStarted"
                            text="Roll-off Started" />
                        <Switch
                            id="switchRollOffStarted"
                            state="{employee>/statusRollOffStarted}"  customTextOn="Yes" customTextOff="No" />
                    </HBox>
                    
                    <HBox
                        id="hboxHandoverKT"
                        justifyContent="Start"
                        alignItems="Center"
                        width="50%"
                        class="sapUiSmallMarginTop">
                        <Text
                            id="txtHandoverKT"
                            text="Handover/KT Begun" />
                        <Switch
                            id="switchHandoverKT"
                            state="{employee>/statusHandoverKTBegun}"  customTextOn="Yes" customTextOff="No" />
                    </HBox>
                </HBox>
                
            </VBox>
        </content>
        
        <buttons>
            <Button
                id="btnCancel"
                text="Cancel"
                press="onCancelEmployee" />
            <Button
                id="btnAddEmployee"
                text="Add Employee"
                type="Emphasized"
                press="onAddEmployeePress" />
        </buttons>
        
    </Dialog>
</core:FragmentDefinition>