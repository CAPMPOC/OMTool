<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    
    <SelectDialog
        id="locationSelectDialog"
        title="Employee Location"
        noDataText="No locations found"
        search=".onLocationSearch"
        confirm=".onLocationConfirm"
        cancel=".onLocationCancel"
        items="{
					    path: '/LocationVH'
				        }"
        growing="true"
        growingThreshold="20">
        
        <StandardListItem
            title="{LocDesc}"
            description="{LocID}"
            type="Active"/>
            
    </SelectDialog>
    
</core:FragmentDefinition>