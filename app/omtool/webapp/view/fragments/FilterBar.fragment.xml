<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    
    <FlexBox >
    <VBox class="sapUiSmallMargin">
        <HBox alignItems="Center" justifyContent="SpaceBetween" width="100%">
            <!-- Search Bar -->
            <SearchField
                id="mainSearchField"
                placeholder="Search..."
                width="500px"
                search=".onSearch"
                class="sapUiTinyMarginEnd"
                visible="true"/>
            
            <!-- Filter Dropdowns Container -->
            <HBox alignItems="Center" justifyContent="End">
                <!-- Dropdown 1 -->
                <ComboBox
                    id="Position"
                    placeholder="Position"
                    width="180px"
                    selectionChange=".onFilterChange"
                    class="sapUiTinyMarginEnd"
                    showClearIcon="true"
                    items="{
					    path: '/AccessibilityVH'
				        }">
                    <core:Item key="{AccessID}" text="{Description}" />
                </ComboBox>
                
                <!-- Value Help -->
                <!-- <Input
                    id="locationValueHelp"
                    placeholder="Select Location"
                    width="200px"
                    showValueHelp="true"
                    valueHelpRequest=".onLocationValueHelp"
                    change=".onLocationChange"
                    class="sapUiTinyMarginEnd"/> -->

                <Input
                    id="locationValueHelp"
                    placeholder="Select Location"
                    width="200px"
                    showClearIcon="true"
                    showValueHelp="true"
                    valueHelpRequest=".onLocationValueHelp"
                    change=".onLocationChange"
                    showSuggestion="true"
                    suggestionItems="{
					    path: '/LocationVH'
				        }"
                    suggest=".onLocationSuggest"
                    suggestionItemSelected=".onLocationSuggestionSelected"
                    class="sapUiTinyMarginEnd">
                    <suggestionItems>
                        <core:Item 
                            key="{LocID}" 
                            text="{LocDesc}"/>
                    </suggestionItems>
                </Input>
                
                <!-- Dropdown 3 -->
                <ComboBox
                    id="filterDropdown3"
                    placeholder="Select KT Status"
                    width="200px"
                    showClearIcon="true"
                    selectionChange=".onKtStatusChange"
                    class="sapUiTinyMarginEnd">
                    <items>
                        <core:Item key="" text="Not Selected"/>
                        <core:Item key="true" text="Yes"/>
                        <core:Item key="false" text="No"/>
                    </items>
                </ComboBox>
                
                <!-- Dropdown 4 -->
                <ComboBox
                    id="filterDropdown4"
                    placeholder="Filter 4"
                    width="180px"
                    selectionChange=".onFilterChange">
                    <items>
                        <core:Item key="all" text="All"/>
                        <core:Item key="option1" text="Option 1"/>
                        <core:Item key="option2" text="Option 2"/>
                    </items>
                </ComboBox>
            </HBox>
        </HBox>
    </VBox>
    </FlexBox>
    
</core:FragmentDefinition>