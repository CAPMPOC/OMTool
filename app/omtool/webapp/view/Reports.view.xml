<mvc:View
    controllerName="com.sap.omtool.omtool.controller.Reports"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns:layout="sap.ui.layout"
    xmlns:form="sap.ui.layout.form"
    xmlns="sap.m"
    xmlns:viz="sap.viz.ui5.controls"
    height="100%">
    
    <Page id="reportsPage" title="Manager Employee Tracker - Reports" showNavButton="false">
        <content>
            <!-- Navigation Bar -->
            <OverflowToolbar id="navigationToolbar" design="Solid" class="sapUiTinyMarginBottom">
                <SegmentedButton id="navSegmentedButton" selectedKey="reports">
                    <items>
                        <SegmentedButtonItem 
                            id="employeeMasterBtn" 
                            icon="sap-icon://employee" 
                            text="Employee Master" 
                            key="employeeMaster"
                            press="onNavigateToEmployeeMaster"/>
                        <SegmentedButtonItem 
                            id="reportsBtn" 
                            icon="sap-icon://bar-chart" 
                            text="Reports" 
                            key="reports"
                            press="onNavigateToReports"/>
                    </items>
                </SegmentedButton>
                <ToolbarSpacer id="navToolbarSpacer"/>
            </OverflowToolbar>

            <!-- Filter Section -->
            <Panel id="filterPanel" 
                headerText="Reports" 
                expandable="false" 
                expanded="true"
                class="sapUiResponsiveMargin">
                <content>
                    <Text text="20 employee(s) matching filters" class="sapUiSmallMarginBegin sapUiTinyMarginTop"/>
                    
                    <OverflowToolbar id="filterToolbar" design="Transparent">
                        <content>
                            <!-- Experience Filter -->
                            <Label text="Experience" labelFor="experienceFilter" class="sapUiTinyMarginBegin"/>
                            <ComboBox id="experienceFilter" 
                                selectedKey="All" 
                                width="150px"
                                change="onFilterChange">
                                <items>
                                    <core:Item key="All" text="All"/>
                                </items>
                            </ComboBox>

                            <!-- New Employee Filter -->
                            <Label text="New Employee" labelFor="newEmployeeFilter" class="sapUiSmallMarginBegin"/>
                            <ComboBox id="newEmployeeFilter" 
                                selectedKey="All" 
                                width="150px"
                                change="onFilterChange">
                                <items>
                                    <core:Item key="All" text="All"/>
                                </items>
                            </ComboBox>

                            <!-- KT Started Filter -->
                            <Label text="KT Started" labelFor="ktStartedFilter" class="sapUiSmallMarginBegin"/>
                            <ComboBox id="ktStartedFilter" 
                                selectedKey="All" 
                                width="150px"
                                change="onFilterChange">
                                <items>
                                    <core:Item key="All" text="All"/>
                                </items>
                            </ComboBox>

                            <!-- Roll-off Started Filter -->
                            <Label text="Roll-off Started" labelFor="rolloffStartedFilter" class="sapUiSmallMarginBegin"/>
                            <ComboBox id="rolloffStartedFilter" 
                                selectedKey="All" 
                                width="150px"
                                change="onFilterChange">
                                <items>
                                    <core:Item key="All" text="All"/>
                                </items>
                            </ComboBox>

                            <!-- Handover/KT Filter -->
                            <Label text="Handover/KT" labelFor="handoverKTFilter" class="sapUiSmallMarginBegin"/>
                            <ComboBox id="handoverKTFilter" 
                                selectedKey="All" 
                                width="150px"
                                change="onFilterChange">
                                <items>
                                    <core:Item key="All" text="All"/>
                                </items>
                            </ComboBox>

                            <!-- Kick-off From Date -->
                            <Label text="Kick-off From" labelFor="kickoffFromDate" class="sapUiSmallMarginBegin"/>
                            <DatePicker id="kickoffFromDate" 
                                placeholder="mm/dd/yyyy"
                                width="150px"
                                change="onFilterChange"/>

                            <!-- Kick-off To Date -->
                            <Label text="Kick-off To" labelFor="kickoffToDate" class="sapUiSmallMarginBegin"/>
                            <DatePicker id="kickoffToDate" 
                                placeholder="mm/dd/yyyy"
                                width="150px"
                                change="onFilterChange"/>

                            <!-- Roll-off Date Filter -->
                            <Label text="Roll-off Date" labelFor="rolloffDateFilter" class="sapUiSmallMarginBegin"/>
                            <ComboBox id="rolloffDateFilter" 
                                selectedKey="All" 
                                width="150px"
                                change="onFilterChange">
                                <items>
                                    <core:Item key="All" text="All"/>
                                </items>
                            </ComboBox>
                        </content>
                    </OverflowToolbar>
                </content>
            </Panel>

            <!-- Charts Section -->
            <ScrollContainer 
    id="chartsScrollContainer"
    height="100%" 
    width="100%" 
    horizontal="true" 
    vertical="false"
    class="sapUiResponsiveMargin">
    
    <FlexBox 
        id="chartsFlexBox"
        direction="Row" 
        wrap="NoWrap"
        justifyContent="Start"
        alignItems="Start"
        class="sapUiSmallMargin">
        
        <!-- KT Started Distribution Chart -->
        <Panel 
            id="ktStartedPanel" 
            headerText="KT Start..." 
            width="350px"
            class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
            <content>
                <VBox 
                    id="ktChartContainer" 
                    alignItems="Center" 
                    justifyContent="Center"
                    height="300px"
                    class="sapUiSmallMargin">
                    <Text text="KT Started: 4 (20%)" class="sapUiSmallMarginBottom"/>
                    <Text text="KT Not Started: 16 (80%)" class="sapUiTinyMarginBottom"/>
                    <!-- Placeholder for chart -->
                    <core:Icon src="sap-icon://pie-chart" size="8rem" color="#0854A0"/>
                    <!-- Navigation arrows -->
                    <HBox class="sapUiTinyMarginTop">
                        <Button icon="sap-icon://navigation-left-arrow" type="Transparent"/>
                        <core:Icon src="sap-icon://circle-task" size="1rem" color="#0854A0" class="sapUiTinyMarginBegin sapUiTinyMarginEnd"/>
                        <Button icon="sap-icon://navigation-right-arrow" type="Transparent"/>
                    </HBox>
                </VBox>
            </content>
        </Panel>

        <!-- Roll-off Started Distribution Chart -->
        <Panel 
            id="rolloffStartedPanel" 
            headerText="Roll-off ..." 
            width="350px"
            class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
            <content>
                <VBox 
                    id="rolloffChartContainer" 
                    alignItems="Center" 
                    justifyContent="Center"
                    height="300px"
                    class="sapUiSmallMargin">
                    <Text text="Roll-off Started: 6 (30%)" class="sapUiSmallMarginBottom"/>
                    <Text text="Roll-off Not Started: 14 (70%)" class="sapUiTinyMarginBottom"/>
                    <!-- Placeholder for chart -->
                    <core:Icon src="sap-icon://pie-chart" size="8rem" color="#0854A0"/>
                    <!-- Navigation arrows -->
                    <HBox class="sapUiTinyMarginTop">
                        <Button icon="sap-icon://navigation-left-arrow" type="Transparent"/>
                        <core:Icon src="sap-icon://circle-task" size="1rem" color="#0854A0" class="sapUiTinyMarginBegin sapUiTinyMarginEnd"/>
                        <Button icon="sap-icon://navigation-right-arrow" type="Transparent"/>
                    </HBox>
                </VBox>
            </content>
        </Panel>

        <!-- Handover/KT Begun Chart -->
        <Panel 
            id="handoverKTPanel" 
            headerText="Handover/KT Begun (among Roll-offs)" 
            width="350px"
            class="sapUiSmallMarginBottom">
            <content>
                <VBox 
                    id="handoverChartContainer" 
                    alignItems="Center" 
                    justifyContent="Center"
                    height="300px"
                    class="sapUiSmallMargin">
                    <Text text="Handover Begun: 3 (50%)" class="sapUiSmallMarginBottom"/>
                    <Text text="Handover Not Begun: 3 (50%)" class="sapUiTinyMarginBottom"/>
                    <!-- Placeholder for chart -->
                    <core:Icon src="sap-icon://pie-chart" size="8rem" color="#0854A0"/>
                    <!-- Navigation arrows -->
                    <HBox class="sapUiTinyMarginTop">
                        <Button icon="sap-icon://navigation-left-arrow" type="Transparent"/>
                        <core:Icon src="sap-icon://circle-task" size="1rem" color="#0854A0" class="sapUiTinyMarginBegin sapUiTinyMarginEnd"/>
                        <Button icon="sap-icon://navigation-right-arrow" type="Transparent"/>
                    </HBox>
                </VBox>
            </content>
        </Panel>
        
    </FlexBox>
</ScrollContainer>

        </content>
    </Page>
</mvc:View>